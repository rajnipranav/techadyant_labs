# =====================================================================
# Techadyant Labs — environment variables
# Frontend (NEXT_PUBLIC_*) is safe to expose. Everything else is SERVER-ONLY
# and must be set in Cloudflare Pages > Settings > Environment variables
# (and in .dev.vars for local `wrangler pages dev`). NEVER commit real values.
# =====================================================================

# --- Supabase (Phase 1: storage; Phase 2: auth) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Server-only (Pages Functions). NEVER ship to the browser.
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret
REPORTS_BUCKET=reports

# --- Razorpay (Phase 3) ---
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_live_xxx
RAZORPAY_KEY_ID=rzp_live_xxx
RAZORPAY_KEY_SECRET=your-razorpay-secret
RAZORPAY_WEBHOOK_SECRET=your-webhook-secret
